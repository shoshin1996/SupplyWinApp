<UserControl x:Class="SupplyWinApp.Presentation.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PrimaryDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with back button -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Back"
                        Command="{Binding BackCommand}"
                        Background="Transparent" Foreground="{StaticResource TextMutedBrush}"
                        BorderThickness="1" BorderBrush="{StaticResource TextMutedBrush}"
                        Padding="16,6" FontSize="12" Cursor="Hand"/>

                <TextBlock Grid.Column="1" Text="{Binding Title}"
                           Foreground="White" FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Placeholder content -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding Title}" Foreground="White"
                       FontSize="28" FontWeight="Light"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="{Binding Message}"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
