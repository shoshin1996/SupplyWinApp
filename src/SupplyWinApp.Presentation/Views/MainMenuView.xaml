<UserControl x:Class="SupplyWinApp.Presentation.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PrimaryDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo_red.png" Width="36" Height="36"
                           Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="SupplySystem" Foreground="White" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Welcome message -->
                <TextBlock Grid.Column="1" Text="{Binding WelcomeMessage}"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Logout button -->
                <Button Grid.Column="2" Content="Logout"
                        Command="{Binding LogoutCommand}"
                        Background="Transparent" Foreground="{StaticResource TextMutedBrush}"
                        BorderThickness="1" BorderBrush="{StaticResource TextMutedBrush}"
                        Padding="16,6" FontSize="12" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Menu Items Grid -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding MenuItems}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Margin="40">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" MaxWidth="700"
                               HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding NavigateCommand}"
                            Style="{StaticResource MenuItemButtonStyle}"
                            Width="200" Margin="8"
                            Padding="20,28">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Icon}" FontSize="28"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
