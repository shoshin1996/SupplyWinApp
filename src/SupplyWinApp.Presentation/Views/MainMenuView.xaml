<UserControl x:Class="SupplyWinApp.Presentation.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Background image with dark overlay -->
        <Image Source="/Assets/swa_login_bg.jpg" Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"/>
        <Rectangle Fill="#DD0D0D1A"/>

        <!-- Main content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Header bar -->
            <Border Grid.Row="0" Background="{StaticResource HeaderDarkBrush}" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Logo + brand name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/logo_red.png" Width="28" Height="28"
                               Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="SUPPLYSYSTEM INTELLIGENT SOFTWARE"
                                   Foreground="White" FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: User icon + CUSTOMIZE -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="CUSTOMIZE" Foreground="White" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Row 1: Sub-header with machine info -->
            <Border Grid.Row="1" Background="{StaticResource SubHeaderBrush}" Padding="16,8">
                <StackPanel>
                    <TextBlock Text="VIRTUAL MACHINE" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding MachineName}" Foreground="White"
                               FontSize="13" FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Row 2: Menu grid (3x2 red buttons) -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding MenuItems}"
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          Margin="40,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" Rows="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding NavigateCommand}"
                                Style="{StaticResource MenuItemButtonStyle}"
                                Width="160" Height="130" Margin="6">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="{Binding Icon}" Width="40" Height="40"
                                       Margin="0,0,0,10"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="White"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Row 3: Bottom action buttons -->
            <StackPanel Grid.Row="3" Margin="16,0,16,12">
                <Button Command="{Binding SelectMachineCommand}"
                        Style="{StaticResource MenuActionButtonStyle}"
                        Margin="0,0,0,6" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="SELECT MACHINE" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding LogoutCommand}"
                        Style="{StaticResource MenuActionButtonStyle}"
                        HorizontalAlignment="Left">
                    <TextBlock Text="LOGOUT" FontWeight="Bold"/>
                </Button>
            </StackPanel>

            <!-- Row 4: Red accent footer bar -->
            <Border Grid.Row="4" Background="{StaticResource AccentRedBrush}"/>
        </Grid>
    </Grid>
</UserControl>
